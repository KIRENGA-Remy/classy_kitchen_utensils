// Prisma schema — Classy Kitchen Utensils
// Prices are whole RWF (Rwandan Franc has no practical sub-unit), stored as Int.

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  nameEn    String
  nameRw    String
  position  Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id            String         @id @default(cuid())
  slug          String         @unique
  nameEn        String
  nameRw        String
  descriptionEn String         @default("")
  descriptionRw String         @default("")
  priceRwf      Int                                  // whole RWF (current price)
  oldPriceRwf   Int?                                 // optional crossed-out price (discount)
  colors        String[]       @default([])          // optional color/variant options
  rating        Float          @default(0)
  reviewCount   Int            @default(0)
  stock         Int            @default(0)
  isActive      Boolean        @default(true)
  isFeatured    Boolean        @default(false)
  category      Category       @relation(fields: [categoryId], references: [id])
  categoryId    String
  images        ProductImage[]
  reviews       Review[]
  orderItems    OrderItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String  @default("")
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@index([productId])
}

model Order {
  id            String        @id @default(cuid())
  reference     String        @unique
  customerName  String
  customerPhone String
  customerEmail String?
  deliveryNote  String?
  totalRwf      Int
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  items         OrderItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

model OrderItem {
  id           String  @id @default(cuid())
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  product      Product @relation(fields: [productId], references: [id])
  productId    String
  nameEn       String                 // snapshot of name at purchase time
  unitPriceRwf Int                    // snapshot of price at purchase time
  quantity     Int

  @@index([orderId])
}

model Review {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  author    String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  @@index([productId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}
